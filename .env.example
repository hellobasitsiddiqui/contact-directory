# Copy to .env for `docker compose up`. Set real values for any real deployment.
# .env is git-ignored; never commit real secrets.

# Postgres credentials (used by both the db and app containers)
POSTGRES_DB=contacts
POSTGRES_USER=contacts
POSTGRES_PASSWORD=change-me-strong-db-password

# App secrets
APP_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
APP_DEFAULT_ADMIN_PASSWORD=change-me-strong-admin-password

# TLS via the Caddy reverse proxy (docker-compose.tls.yml, CD-027). Only needed
# when running the TLS overlay. DOMAIN must resolve to this host (or "localhost"
# for a self-signed local trial).
DOMAIN=contacts.example.com
